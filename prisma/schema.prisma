generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  GERENTE
  OPERADOR
  CLIENTE
}

enum Plan {
  FREE
  BASIC
  PRO
}

enum OrderStatus {
  RASCUNHO
  PENDENTE_APROVACAO
  APROVADO
  EM_PRODUCAO
  PRONTO
  EM_ENTREGA
  ENTREGUE
  CANCELADO
}

enum PaymentMethod {
  PIX
  BOLETO
  CARTAO_CREDITO
  CARTAO_DEBITO
  DINHEIRO
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

enum InvoiceStatus {
  PROCESSANDO
  EMITIDA
  CANCELADA
  ERRO
}

enum StockMovementType {
  ENTRADA
  SAIDA
  AJUSTE
}

enum FactoryOrderStatus {
  SOLICITADO   // Pedido feito à fábrica
  EM_PRODUCAO  // Fábrica produzindo
  A_CAMINHO    // Enviado, a caminho
  RECEBIDO     // Recebido no estoque
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  cnpj           String?  @unique
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  plan           Plan     @default(FREE)
  active         Boolean  @default(true)
  focusNfeToken  String?
  nfeAmbiente    String?  @default("homologacao")
  mpPublicKey    String?
  mpAccessToken  String?

  // Dados fiscais para emissão de NF-e
  ie               String?  // Inscrição Estadual
  im               String?  // Inscrição Municipal
  cnae             String?  // Código CNAE (7 dígitos)
  regimeTributario String?  // "1" Simples Nacional | "2" Simples Excesso | "3" Regime Normal
  cep              String?
  logradouro       String?
  numero           String?
  complemento      String?
  bairro           String?
  codigoCidade     String?  // Código IBGE do município (7 dígitos)

  // E-mail de envio (remetente nas notificações — deve ser de domínio verificado no Resend)
  emailRemetente   String?

  // Z-API (WhatsApp)
  zapiInstanceId   String?
  zapiToken        String?

  // Configurações de notificações automáticas (JSON — ver lib/notificacoes.ts)
  notificacoes     Json?

  // Personalização da loja pública
  lojaCorPrimaria  String?  @default("#f59e0b")
  lojaBannerUrl    String?
  lojaLogoUrl      String?
  lojaDescricao    String?
  lojaPedidoMinimo Decimal? @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users     User[]
  products  Product[]
  categories ProductCategory[]
  orders    Order[]
  payments       Payment[]
  invoices       Invoice[]
  costs          OperationalCost[]
  stockItems     StockItem[]
  factoryOrders  FactoryOrder[]
  clientPrices   ClientProductPrice[]
  crmCards       CrmCard[]

  @@index([slug])
}

// ============================================================
// USERS & AUTH (NextAuth.js v5)
// ============================================================

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String?
  nomeFantasia  String?   // Nome fantasia / nome comercial (ex: "Hamburgueria do João")
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(CLIENTE)
  active        Boolean   @default(true)
  cnpj          String?
  cpf           String?
  ie            String?  // Inscrição Estadual (para NF-e: indIEDest e consumidor_final)
  // Endereço fiscal (para NF-e como destinatário)
  cep           String?
  logradouro    String?
  numero        String?
  complemento   String?
  bairro        String?
  city          String?
  state         String?
  codigoCidade  String?
  phone         String?
  // Contato financeiro
  financeiroNome   String?
  financeiroEmail  String?
  financeiroPhone  String?
  // Tomador de decisão
  decisorNome      String?
  decisorEmail     String?
  decisorPhone     String?
  // Observações internas
  observacoes      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  orders         Order[]  @relation("OrderClient")
  approvedOrders Order[]  @relation("OrderApprover")
  clientPrices   ClientProductPrice[]
  crmCards       CrmCard[]

  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// PRODUCTS
// ============================================================

model ProductCategory {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  products Product[]

  @@index([tenantId])
}

model Product {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  unit        String           @default("un")
  minQuantity    Decimal?         @db.Decimal(10, 3)
  shelfLifeDays  Int?
  // Preços por embalagem
  pricePacote    Decimal?         @db.Decimal(10, 2)
  priceCaixa     Decimal?         @db.Decimal(10, 2)
  labelPacote    String?          // ex: "Pacote c/ 10 un"
  labelCaixa     String?          // ex: "Caixa c/ 24 un"
  qtdCaixa       Int?             // Unidades por caixa — usado para conversão no estoque
  // Dimensões físicas
  weightGrams    Int?             // Peso unitário em gramas
  diameterCm     Decimal?         @db.Decimal(5, 1) // Diâmetro em cm
  // NF-e
  ncm            String?          // Código NCM para NF-e (8 dígitos)
  cfop           String?          @default("5102") // CFOP padrão — 5102 interno, 6102 interestadual
  // NF-e — Tributação ICMS / Substituição Tributária
  icmsCsosn             String?  @default("102") // CSOSN: "102" = sem ST (padrão) | "500" = ICMS já recolhido por ST
  stBcRetidoUnit        Decimal? @db.Decimal(12, 4) // vBCSTRet por unidade (base de cálculo do ICMS-ST retido)
  stAliquotaFinal       Decimal? @db.Decimal(5, 2)  // pST — alíquota suportada pelo consumidor final (%)
  stValorSubstitutoUnit Decimal? @db.Decimal(12, 4) // vICMSSubstituto por unidade
  stIcmsRetidoUnit      Decimal? @db.Decimal(12, 4) // vICMSSTRet por unidade (ICMS-ST retido)
  active         Boolean          @default(true)
  imageUrl       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  orderItems    OrderItem[]
  stockItem     StockItem?
  clientPrices  ClientProductPrice[]

  @@index([tenantId])
}

// ============================================================
// FACTORY ORDERS (pedidos à fábrica / fornecedor)
// ============================================================

model FactoryOrder {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String             // Produto ou descrição
  quantity    String?            // Ex: "500 un", "20 kg"
  status      FactoryOrderStatus @default(SOLICITADO)
  notes       String?
  expectedAt  DateTime?          // Previsão de entrega da fábrica
  receivedAt  DateTime?
  position    Int                @default(0) // Ordem dentro da coluna
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tenantId])
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId        String
  client          User        @relation("OrderClient", fields: [clientId], references: [id])
  status          OrderStatus @default(RASCUNHO)
  requestedDate          DateTime?
  scheduledDeliveryDate  DateTime?
  deliveryAddress String?
  notes           String?
  internalNotes   String?
  paymentMethod   PaymentMethod?
  approvedAt      DateTime?
  approvedById    String?
  approvedBy      User?       @relation("OrderApprover", fields: [approvedById], references: [id])
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items    OrderItem[]
  payments Payment[]
  invoices Invoice[]

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  notes     String?

  @@index([orderId])
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  installments Int           @default(1)
  installmentN Int           @default(1)
  dueDate      DateTime
  paidAt       DateTime?
  mpPaymentId  String?
  mpStatus     String?
  status       PaymentStatus @default(PENDENTE)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([orderId])
  @@index([status])
  @@index([dueDate])
}

// ============================================================
// INVOICES (NF-e)
// ============================================================

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number      String?
  series      String?       @default("1")
  focusNfeRef String?
  accessKey   String?
  issuedAt    DateTime?
  xmlUrl      String?
  pdfUrl      String?
  status      InvoiceStatus @default(PROCESSANDO)
  errorMsg    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([orderId])
}

// ============================================================
// STOCK CONTROL
// ============================================================

model StockItem {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId      String    @unique
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity       Decimal   @default(0) @db.Decimal(10, 3)
  alertThreshold Decimal?  @db.Decimal(10, 3)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  movements StockMovement[]

  @@index([tenantId])
}

model StockMovement {
  id          String            @id @default(cuid())
  tenantId    String
  stockItemId String
  stockItem   StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  type        StockMovementType
  quantity    Decimal           @db.Decimal(10, 3)
  reason      String?
  orderId     String?
  createdAt   DateTime          @default(now())

  @@index([tenantId])
  @@index([stockItemId])
}

// ============================================================
// PREÇOS PERSONALIZADOS POR CLIENTE
// ============================================================

model ClientProductPrice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String
  client      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Preços customizados (null = usa o padrão do produto)
  price        Decimal? @db.Decimal(10, 2)
  pricePacote  Decimal? @db.Decimal(10, 2)
  priceCaixa   Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, productId])
  @@index([tenantId])
  @@index([clientId])
}

// ============================================================
// ERP - OPERATIONAL COSTS
// ============================================================

model OperationalCost {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  date        DateTime
  recurring   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
}

// ============================================================
// CRM
// ============================================================

// Tab 1 stages: PRIMEIRO_CONTATO | ENVIO_AMOSTRA | NEGOCIACAO | FECHADO
// Tab 2 stages: PESQUISA_SATISFACAO | VERIFICACAO_ESTOQUE | RECOMPROU
model CrmCard {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Lead info (pode não ter User cadastrado ainda)
  clientId  String?
  client    User?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadName  String?
  leadPhone String?
  leadEmail String?
  leadSource String? // "indicação", "instagram", "loja", etc.

  tab       String  @default("NOVOS")           // "NOVOS" | "POS_VENDA"
  stage     String  @default("PRIMEIRO_CONTATO") // ver valores acima
  position  Int     @default(0)

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, tab, stage])
  @@index([clientId])
}
